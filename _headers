/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# HTML, robots and sitemap must never be served stale by any CDN/cache layer.
# (The 2026-07-05 incident: the edge kept serving the pre-rebuild SPA homepage,
#  a fallback-HTML robots.txt and a missing sitemap for days after deploy.)
/
  Cache-Control: public, max-age=0, must-revalidate

/brands
  Cache-Control: public, max-age=0, must-revalidate

/brands/*
  Cache-Control: public, max-age=0, must-revalidate

/models
  Cache-Control: public, max-age=0, must-revalidate

/models/*
  Cache-Control: public, max-age=0, must-revalidate

/stories/*
  Cache-Control: public, max-age=0, must-revalidate

/news
  Cache-Control: public, max-age=0, must-revalidate

/news/*
  Cache-Control: public, max-age=0, must-revalidate

/tech
  Cache-Control: public, max-age=0, must-revalidate

/about
  Cache-Control: public, max-age=0, must-revalidate

/quote
  Cache-Control: public, max-age=0, must-revalidate

/privacy
  Cache-Control: public, max-age=0, must-revalidate

/zh
